  "syntaxRefTitle": "朱码语法参考",
  "syntaxRefLines": [
    "> #### 标题",
    "> [-< ref: headings >-]",
    "> | \\# 标题1 | h1 |",
    "> | \\## 标题2 | h2 |",
    "> | \\### 标题3 | h3 |",
    "> | \\#### 标题4 | h4 |",
    "> | \\##### 标题5 | h5 |",
    "> | \\###### 标题6 | h6 |",
    "",
    "> #### 文本修饰",
    "> [-< ref: text-decors >-]",
    "> | \\**粗体\\** | **粗体** | [-[ ref: bold strong ]-]",
    "> | \\%%斜体\\%% | %%斜体%% | [-[ ref: italic em ]-]",
    "> | \\__下划线\\__ | __下划线__ | [-[ ref: underline ins ]-]",
    "> | \\~~删除线\\~~ | ~~删除线~~ | [-[ ref: strike del ]-]",
    "> | \\!!高亮\\!! | !!高亮!! | [-[ ref: highlight mark ]-]",
    "> | \\^^上标\\^^ | X^^2^^ | [-[ ref: sup ]-]",
    "> | \\<<下标\\>> | H<<2>>O | [-[ ref: sub ]-]",
    "> | \\@@小字体\\@@ | @@小字体@@ | [-[ ref: small ]-]",
    "> | \\{{文字^音标\\}} | {{文字^音标}} | [-[ ref: annotation`/`ruby ]-]",
    "",
    "> #### 代码",
    "> [-< ref: codes >-]",
    "> | \\`Javascript\\` | 行内代码 | [-[ ref: code-inline ]-]",
    "> | \\`\\`\\`\\nJavascript\\n\\`\\`\\` | 代码块 | [-[ ref: code-block ]-]",
    "",
    "> #### 列表",
    "> [-< ref: lists >-]",
    "> | + 无序  | ● 实心圆 | [-[ ref: lists-unordered ul-disc ]-]",
    "> | - 无序  | ○ 空心圆 | [-[ ref: lists-unordered ul-circle ]-]",
    "> | * 无序  | ■ 方块 | [-[ ref: lists-unordered ul-square ]-]",
    "> | 1. 有序  | 1. 阿拉伯数字 | [-[ ref: lists-ordered ol-1 ]-]",
    "> | i. 有序  | i. 小写罗马数字 | [-[ ref: lists-ordered ol-i ]-]",
    "> | I. 有序  | I. 大写罗马数字 | [-[ ref: lists-ordered ol-I ]-]",
    "> | a. 有序  | a. 小写字母 | [-[ ref: lists-ordered ol-a ]-]",
    "> | A. 有序  | A. 大写字母 | [-[ ref: lists-ordered ol-A ]-]",
    "> | +*+ 任务  | ✅ 已完成 | [-[ ref: lists-task task-done ]-]",
    "> | -*- 任务  | ☐ 未完成 | [-[ ref: lists-task task-undone ]-]",
    "",
    "> #### 表格",
    "> [-< ref: table >-]",
    "> \\| 表头1 | 表头2 |",
    "> \\|====|====| ← 【分隔行】",
    "> \\| 表体1 | 表体2 |",
    "> \\|====|====| ← 【分隔行】",
    "> \\| 表尾1 | 表尾2 |",
    "",
    "> #### 嵌入",
    "> [-< ref: embeds >-]",
    "> | \\(文字){URL}  | 链接 | [-[ ref: link a ]-]",
    "> | !\\(alt){URL}  | 图片 | [-[ ref: image img ]-]",
    "> | !\\!!\\n\\! 图片标题\\n!\\(alt){URL}\\n!\\!! | 图片块 | [-[ ref: image-block figure ]-]",
    "> | ~\\(){URL\\|媒体类型} | 音频 | [-[ ref: audio ]-]",
    "> | $\\(){URL\\|媒体类型} | 视频 | [-[ ref: video ]-]",
    "",
    "> #### 引用",
    "> [-< ref: quotes >-]",
    "> | \\>>引文\\<< | 行内引用 | [-[ ref: quote-inline ]-]",
    "> | > 一级\\n>> 二级 | 引用块 | [-[ ref: quote-block ]-]",
    "",
    "> #### 描述",
    "> [-< ref: descs >-]",
    "> | ;;名称::描述;; | 定义列表 | [-[ ref: deflist dl ]-]",
    "> | ;;;\\n可包含任意语法\\n;;; | 详情块 | [-[ ref: details ]-]",
    "",
    "> #### 其它",
    "> [-< ref: misc >-]",
    "> | ((数值//总额)) | 进度条 | [-[ ref: progress ]-]",
    "> | -\\-- | 水平分隔线 | [-[ ref: hr ]-]",
    "> | :\\:smile:\\: | 表情😄 | [-[ enable: emoji ]-]",
    "> | {{{\\nCSS\\n}}} | 样式块 | [-[ enable: style ]-]",
    "",
    "> #### 全局属性",
    "> [-< ref: attrs >-]",
    "> | [A\\[ center ]A] | align属性 | [-[ ref: attr-align ]-]",
    "> | [C\\[ class ]C] | class属性 | [-[ ref: attr-class ]-]",
    "> | [D\\[ rtl ]D] | dir属性 | [-[ ref: attr-dir ]-]",
    "> | [I\\[ id ]I] | id属性 | [-[ ref: attr-id ]-]",
    "> | [L\\[ en ]L] | lang属性 | [-[ ref: attr-lang ]-]",
    "> | [T\\[ title ]T] | title属性 | [-[ ref: attr-title ]-]",
    "> | [-\\[ key: value ]-] | data-*属性 | [-[ ref: attr-data ]-]",
    "",
    "> #### 专用属性",
    "> | __**!**__1. 有序 | __<ol>__的**reversed**属性 |",
    "> | \\| 单元格 __**&<正整数>&**__ \\| | __<td>__的**colspan**属性 |",
    "> | \\| 单元格 __**&/integer/&**__ \\| | __<td>__的**rowspan**属性 |",
    "> | ()\\{URL__**=>目标窗口**__} | __<a>__的**target**属性 |",
    "> | !( __**[宽\\|高]**__ )\\{URL}\\n$( __**[宽\\|高]**__ )\\{URL\\|media type} | __<img>__和__<video>__的**width**和**height**属性 |",
    "> | ~( __**_**__ __**&**__ __**@**__ __**!**__ )\\{URL\\|媒体类型}\\n$( __**_**__ __**&**__ __**@**__ __**!**__ )\\{URL\\|媒体类型} | __<audio>__和__<video>__的各种控制属性 |",
    "> | $(__**{封面图网址}**__)\\{URL\\|media type} | __<video>__的 **poster**属性 |",
    "> | >\\>引文 __**<=URL**__<\\<\\n\\> quotes__**<=URL**__ | __<q>__和__<blockquote>__的**cite**属性 |",
    "> | ;;;\\n可包含任意语法\\n;;;__**>**__ | __<detail>__的**open**属性 |",
    ""
  ]
}